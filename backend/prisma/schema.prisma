  @@map("invoice_status_histories")
}

enum CommissionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CommissionBase {
  BEFORE_DISCOUNT
  AFTER_DISCOUNT
}

enum CommissionStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model TreatmentAssignment {
  id String @id @default(uuid())

  treatmentItemId String

  employeeId String

  slotKey String?

  workQty Decimal @db.Decimal(18, 2)

  notes String?

  createdAt DateTime @default(now())

