  @@index([employeeId])
  @@index([effectiveDate])
  @@map("employee_salary_settings")
}

// =====================================================
// LOANS (Kasbon)
// =====================================================

enum LoanStatus {
  ACTIVE
  PAID_OFF
  CANCELLED
}

model Loan {
  id String @id @default(uuid())

  employeeId String
  branchId   String

  loanNo String @unique

  totalAmount      Decimal @db.Decimal(18, 2)
  remainingAmount  Decimal @db.Decimal(18, 2)
  monthlyDeduction Decimal @db.Decimal(18, 2)

  startDate DateTime
  endDate   DateTime?

  status LoanStatus @default(ACTIVE)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Employee        @relation(fields: [employeeId], references: [id])
  branch     Branch          @relation(fields: [branchId], references: [id])
  repayments LoanRepayment[]

  @@index([employeeId])
  @@index([branchId])
  @@index([status])
  @@map("loans")
}

model LoanRepayment {
  id String @id @default(uuid())

  loanId    String
  payrollId String?

  amount Decimal @db.Decimal(18, 2)

  paidAt DateTime

  notes String?

  createdAt DateTime @default(now())

  loan    Loan     @relation(fields: [loanId], references: [id])
  payroll Payroll? @relation(fields: [payrollId], references: [id])

  @@index([loanId])
  @@index([payrollId])
  @@map("loan_repayments")
}

// =====================================================
// PAYROLL
// =====================================================

enum PayrollStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
}

enum PayrollItemType {
  INCOME
  DEDUCTION
}

model Payroll {
  id String @id @default(uuid())

  employeeId String
  branchId   String

  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  status PayrollStatus @default(DRAFT)

  grossIncome     Decimal @db.Decimal(18, 2) @default(0)
  totalDeductions Decimal @db.Decimal(18, 2) @default(0)
  netSalary       Decimal @db.Decimal(18, 2) @default(0)

  approvedBy String?
  approvedAt DateTime?

  paidAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  items      PayrollItem[]
  repayments LoanRepayment[]

  @@unique([employeeId, periodStart])
  @@index([employeeId])
  @@index([branchId])
  @@index([status])
  @@map("payrolls")
}

model PayrollItem {
  id String @id @default(uuid())

  payrollId String

  type     PayrollItemType
  category String
  label    String

  amount   Decimal  @db.Decimal(18, 2)
  quantity Decimal? @db.Decimal(10, 2)
  rate     Decimal? @db.Decimal(18, 2)

  isAuto Boolean @default(true)

  notes String?

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@map("payroll_items")
}

// =====================================================
// CLIENT CONSULTATION NOTES
// =====================================================

model ClientConsultationNote {
  id                     String   @id @default(uuid())
  invoiceId              String   @unique
  customerId             String
  branchId               String
  filledByEmployeeId     String?

  // A. Profil Klien
  profession             String?
  professionOther        String?
  ageRange               String?
  dailyStyling           String[]
  dailyStylingOther      String?

  // B. Motivasi & Perjalanan
  discoveryChannel       String?
  discoveryChannelDetail String?
  reasonForService       String[]
  reasonForServiceOther  String?
  hesitation             String[]
  hesitationOther        String?
  previousExpType        String?
  previousSalonName      String?
  reasonSwitchToNia      String?

  // C. Catatan Sesi
  issuesDuringUse        String?
  changesAfterUse        String?
  interestingNote        String
  additionalNotes        String?

  filledAt               DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  invoice          Invoice   @relation(fields: [invoiceId], references: [id])
  customer         Customer  @relation(fields: [customerId], references: [id])
  branch           Branch    @relation(fields: [branchId], references: [id])
  filledByEmployee Employee? @relation("ConsultationFilledBy", fields: [filledByEmployeeId], references: [id])

  @@index([customerId])
  @@index([branchId])
  @@index([filledByEmployeeId])
  @@map("client_consultation_notes")
}
