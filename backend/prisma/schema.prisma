model AuditLog {
  id String @id @default(uuid())

  userId String?

  module String

  action String

  recordId String?

  oldData Json?

  newData Json?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([module])
  @@index([recordId])
  @@map("audit_logs")
