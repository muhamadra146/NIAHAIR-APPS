  item Item @relation(fields: [itemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  assignments TreatmentAssignment[]

  materialUsages MaterialUsage[]

  @@index([treatmentSessionId])
  @@index([itemId])
  @@index([unitId])
  @@map("treatment_items")
