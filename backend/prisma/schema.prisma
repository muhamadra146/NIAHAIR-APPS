model TreatmentMedia {
  id String @id @default(uuid())

  treatmentSessionId String

  mediaType MediaType

  fileUrl String

  notes String?

  createdAt DateTime @default(now())

  treatmentSession TreatmentSession @relation(fields: [treatmentSessionId], references: [id])

