enum SyncDirection {
  ACCURATE_TO_APP
  APP_TO_ACCURATE
}

enum SyncStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Setting {
  id String @id @default(uuid())

  key String @unique

  value String

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model SyncQueue {
  id String @id @default(uuid())

  entityType String

  entityId String

  direction SyncDirection

  status SyncStatus

  retryCount Int @default(0)

  payload Json?

  response Json?

  errorMessage String?

  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([entityType])
  @@map("sync_queues")
}

model SyncLog {
  id String @id @default(uuid())

  queueId String?

  entityType String

  entityId String?

  requestPayload Json?

  responsePayload Json?

  status SyncStatus

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([entityType])
  @@map("sync_logs")
}

model BackgroundJob {
  id String @id @default(uuid())

  jobName String

  status JobStatus

  payload Json?

  startedAt DateTime?

  finishedAt DateTime?

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([jobName])
  @@index([status])
  @@map("background_jobs")
}

model WebhookLog {
  id String @id @default(uuid())

  source String

  event String

  payload Json?

  processed Boolean @default(false)

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([source])
  @@index([event])
  @@map("webhook_logs")
}

model AccurateCredential {
  id String @id @default(uuid())

  sessionId String?

  databaseId String?

  accessToken String?

  refreshToken String?

  expiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accurate_credentials")
}

model AccurateMapping {
  id String @id @default(uuid())

  entityType String

  localId String

  accurateId Int

  lastSyncAt DateTime?

  createdAt DateTime @default(now())

  @@unique([entityType, localId])
  @@index([accurateId])
  @@map("accurate_mappings")
}
