enum SyncDirection {
  ACCURATE_TO_APP
  APP_TO_ACCURATE
}

enum SyncStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum SyncEntityType {
  CUSTOMER
  WAREHOUSE
  ITEM
  UNIT
  ITEM_UNIT
  ITEM_PRICE
  INVENTORY
  DEPOSIT
  INVOICE
  PAYMENT
  DEPOSIT_PAYMENT
}

enum SyncQueueStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Setting {
  id String @id @default(uuid())

  key String @unique

  value String

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model SyncQueue {
  id String @id @default(uuid())

  entityType SyncEntityType

  entityId String?

  direction SyncDirection

  status SyncQueueStatus @default(PENDING)

  payload Json?

  attempt    Int @default(0)
  maxAttempt Int @default(3)

  errorMessage String?

  startedAt   DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("sync_queues")
}

model SyncLog {
  id String @id @default(uuid())

  queueId String?

  entityType String

  entityId String?

  requestPayload Json?

  responsePayload Json?

  status SyncStatus

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([entityType])
  @@map("sync_logs")
}

model BackgroundJob {
  id String @id @default(uuid())

  jobName String

  status JobStatus

  payload Json?

  startedAt DateTime?

  finishedAt DateTime?

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([jobName])
  @@index([status])
  @@map("background_jobs")
}

model WebhookLog {
  id String @id @default(uuid())

  source String

  event String

  payload Json?

  processed Boolean @default(false)

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([source])
  @@index([event])
  @@map("webhook_logs")
}

model AccurateCredential {
  id String @id @default(uuid())

