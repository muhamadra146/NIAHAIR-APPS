model CommissionCategory {
  id String @id @default(uuid())

  code String @unique
  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items           Item[]
  commissionRules CommissionRule[]

  @@map("commission_categories")
}

model CommissionRule {
  id String @id @default(uuid())

  employeeId           String
  commissionCategoryId String
  slotKey              String?

  commissionType CommissionType

  commissionValue Decimal @db.Decimal(18, 2)

  commissionBase CommissionBase @default(AFTER_DISCOUNT)

  effectiveDate DateTime
  endDate       DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  commissionCategory CommissionCategory @relation(fields: [commissionCategoryId], references: [id])

  commissions Commission[]

  @@unique([employeeId, commissionCategoryId, slotKey, effectiveDate])
  @@index([employeeId])
  @@index([commissionCategoryId])
  @@map("commission_rules")
}

model Commission {
  id String @id @default(uuid())

  invoiceId String

  invoiceItemId String?

  treatmentAssignmentId String

  employeeId String

  serviceItemId String

  commissionRuleId String?

  workQty   Decimal? @db.Decimal(18, 2)

  workRatio Decimal? @db.Decimal(18, 6)

  commissionType CommissionType

  commissionValue Decimal @db.Decimal(18, 2)

  commissionBase CommissionBase

  baseAmount Decimal @db.Decimal(18, 2)

  commissionAmount Decimal @db.Decimal(18, 2)

  status CommissionStatus

  approvedBy String?

  approvedAt DateTime?

  paidBy String?

  paidAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  invoiceItem InvoiceItem? @relation(fields: [invoiceItemId], references: [id])

  treatmentAssignment TreatmentAssignment @relation(fields: [treatmentAssignmentId], references: [id])

  employee Employee @relation(fields: [employeeId], references: [id])

  serviceItem Item @relation(fields: [serviceItemId], references: [id])

  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id])

  @@unique([treatmentAssignmentId])
  @@index([invoiceId])
  @@index([employeeId])
  @@index([status])
  @@index([commissionRuleId])
  @@map("commissions")
}

model BranchCommissionRule {
  id String @id @default(uuid())

  branchId String

  employeeId String

  commissionType CommissionType

  commissionValue Decimal @db.Decimal(18, 2)

  effectiveDate DateTime

  endDate DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  branch   Branch   @relation(fields: [branchId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("branch_commission_rules")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  EARLY_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleType {
  WORK
  OFF
  LEAVE
}

enum MediaType {
  BEFORE
  AFTER
}

model Attendance {
  id String @id @default(uuid())

  staffScheduleId String @unique
  employeeId      String
  branchId        String
  workDate        DateTime @db.Date

  checkInAt  DateTime?
  checkOutAt DateTime?

  checkInLatitude   Decimal? @db.Decimal(10, 7)
  checkInLongitude  Decimal? @db.Decimal(10, 7)
  checkOutLatitude  Decimal? @db.Decimal(10, 7)
  checkOutLongitude Decimal? @db.Decimal(10, 7)

  checkInPhotoUrl  String?
  checkOutPhotoUrl String?

  status AttendanceStatus @default(ABSENT)

  lateMinutes       Int @default(0)
  earlyLeaveMinutes Int @default(0)
  overtimeMinutes   Int @default(0)
  isHolidayWork     Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffSchedule StaffSchedule @relation(fields: [staffScheduleId], references: [id])
  employee      Employee      @relation(fields: [employeeId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])

  @@index([employeeId])
  @@index([branchId, workDate])
  @@index([workDate])
  @@map("attendances")
}

model EmployeeSchedule {
  id String @id @default(uuid())

  employeeId String

  scheduleDate DateTime

  startTime DateTime?

  endTime DateTime?

  scheduleType ScheduleType

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, scheduleDate])
  @@index([employeeId])
  @@map("employee_schedules")
}

model Leave {
  id String @id @default(uuid())

  employeeId String

  startDate DateTime

  endDate DateTime

  reason String?

  status LeaveStatus

  approvedBy String?

  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("leaves")
}

model TreatmentSession {
  id String @id @default(uuid())

  appointmentId String?

  customerId String

  invoiceId String?

  branchId String

  startedAt DateTime?

  completedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  customer Customer @relation(fields: [customerId], references: [id])

  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  branch Branch @relation(fields: [branchId], references: [id])

  treatmentItems TreatmentItem[]

  media TreatmentMedia[]

  @@index([appointmentId])
  @@index([customerId])
  @@map("treatment_sessions")
}

