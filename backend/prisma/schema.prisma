  overtimeRatePerHour          Decimal @db.Decimal(18, 2) @default(0)
  holidayOvertimeRate          Decimal @db.Decimal(18, 2) @default(0)
  lateDeductionPerMinute       Decimal @db.Decimal(18, 2) @default(0)
  absentDeductionPerDay        Decimal @db.Decimal(18, 2) @default(0)
  earlyLeaveDeductionPerMinute Decimal @db.Decimal(18, 2) @default(0)
