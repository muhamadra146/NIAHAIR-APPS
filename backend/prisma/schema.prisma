generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// MASTER DATA - BATCH 1
// =====================================================

enum Gender {
  MALE
  FEMALE
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// =====================================================
// BRANCHES
// =====================================================

model Branch {
  id String @id @default(uuid())

  code String @unique
  name String

  address  String?
  city     String?
  province String?
  phone    String?

  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  radiusMeters Int      @default(100)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeEmployees           Employee[]              @relation("EmployeeHomeBranch")
  employeeBranchHistories EmployeeBranchHistory[]
  employeeBranches        EmployeeBranch[]

  itemPrices            ItemPrice[]
  warehouses            Warehouse[]
  invoices              Invoice[]
  appointments          Appointment[]
  deposits              Deposit[]
  payments              Payment[]
  treatmentSessions     TreatmentSession[]
  branchCommissionRules BranchCommissionRule[]
  staffSchedules        StaffSchedule[]
  attendances           Attendance[]
  loans                 Loan[]
  payrolls              Payroll[]
  consultationNotes     ClientConsultationNote[]

  @@map("branches")
}

// =====================================================
// USER ROLES
// =====================================================

model UserRole {
  id String @id @default(uuid())

  code String @unique
  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("user_roles")
}

// =====================================================
// USERS
// =====================================================

model User {
  id String @id @default(uuid())

  userRoleId String
  employeeId String @unique

  email String @unique

  passwordHash String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role     UserRole @relation(fields: [userRoleId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([userRoleId])
  @@index([employeeId])
  @@map("users")
}

// =====================================================
// EMPLOYEE ROLES
// =====================================================

model EmployeeRole {
  id String @id @default(uuid())

  code String @unique
  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@map("employee_roles")
}

// =====================================================
// EMPLOYEES
// =====================================================

model Employee {
  id String @id @default(uuid())

  roleId       String
  homeBranchId String?

  employeeCode String @unique

  name String

  phone String?
  email String? @unique

  hireDate DateTime?

  birthDate DateTime?

  address String?

  emergencyContact String?

  commissionEnabled Boolean @default(true)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role       EmployeeRole @relation(fields: [roleId], references: [id])
  homeBranch Branch?      @relation("EmployeeHomeBranch", fields: [homeBranchId], references: [id])

  branchHistories  EmployeeBranchHistory[]
  employeeBranches EmployeeBranch[]
  user             User?

  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  createdDeposits     Deposit[]     @relation("DepositCreatedBy")
  createdInvoices     Invoice[]     @relation("InvoiceCreatedBy")
  createdPayments     Payment[]     @relation("PaymentCreatedBy")
  filledConsultations ClientConsultationNote[] @relation("ConsultationFilledBy")

  appointmentStaffs     AppointmentStaff[]
  treatmentAssignments  TreatmentAssignment[]
  commissionRules       CommissionRule[]
  commissions           Commission[]
  attendances           Attendance[]
  schedules             EmployeeSchedule[]
  leaves                Leave[]
  branchCommissionRules BranchCommissionRule[]
  staffSchedules        StaffSchedule[]
  salarySettings        EmployeeSalarySettings[]
  loans                 Loan[]
  payrolls              Payroll[]

  @@index([roleId])
  @@index([homeBranchId])
  @@map("employees")
}

// =====================================================
// EMPLOYEE BRANCH HISTORIES
// =====================================================

model EmployeeBranchHistory {
  id String @id @default(uuid())

  employeeId String
  branchId   String

  startDate DateTime
  endDate   DateTime?

  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@index([employeeId])
  @@index([branchId])
  @@map("employee_branch_histories")
}

// =====================================================
// EMPLOYEE BRANCHES (access permissions per branch)
// =====================================================

model EmployeeBranch {
  id String @id @default(uuid())

  employeeId String
  branchId   String

  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId],   references: [id])

  @@unique([employeeId, branchId])
  @@index([employeeId])
  @@index([branchId])
  @@map("employee_branches")
}

// =====================================================
// MEMBERSHIPS
// =====================================================

model Membership {
  id String @id @default(uuid())

  name String

  price Decimal @db.Decimal(18, 2)

  durationDays Int

  discountType  DiscountType
  discountValue Decimal      @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerMemberships CustomerMembership[]
  customers           Customer[]
  membershipHistories MembershipHistory[]

  @@map("memberships")
}

// =====================================================
// CUSTOMER SYNC ENUMS
// =====================================================

enum CustomerSyncSource {
  LOCAL
  ACCURATE
}

enum CustomerSyncStatus {
  PENDING
  SYNCED
  FAILED
}

// =====================================================
// CUSTOMERS
// =====================================================

model Customer {
  id String @id @default(uuid())

  accurateCustomerId Int? @unique

  customerNo String? @unique

  name String

  mobilePhone String?

  email String?

  address String?

  city     String?
  province String?

  birthDate DateTime?

  gender Gender?

  membershipId String?

  notes String?

  lastVisitAt DateTime?

  isActive Boolean @default(true)

  syncSource        CustomerSyncSource @default(LOCAL)
  syncStatus        CustomerSyncStatus @default(PENDING)
  syncError         String?
  lastSyncAttemptAt DateTime?

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membership Membership? @relation(fields: [membershipId], references: [id])

  customerMemberships CustomerMembership[]
  membershipHistories MembershipHistory[]

  appointments        Appointment[]
  invoices            Invoice[]
  deposits            Deposit[]
  treatmentSessions   TreatmentSession[]
  customerNotes       CustomerNote[]
  consultationNotes   ClientConsultationNote[]

  @@index([membershipId])
  @@index([name])
  @@index([mobilePhone])
  @@map("customers")
}

// =====================================================
// CUSTOMER MEMBERSHIPS
// =====================================================

model CustomerMembership {
  id String @id @default(uuid())

  customerId   String
  membershipId String

  startDate DateTime
  endDate   DateTime

  status MembershipStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([customerId])
  @@index([membershipId])
  @@map("customer_memberships")
}

// =====================================================
// MEMBERSHIP HISTORIES
// =====================================================

model MembershipHistory {
  id String @id @default(uuid())

  customerId   String
  membershipId String

  startDate DateTime
  endDate   DateTime

  createdBy String?

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([customerId])
  @@index([membershipId])
  @@map("membership_histories")
}

// =====================================================
// ITEM MASTER
// =====================================================

enum ItemType {
  INVENTORY
  SERVICE
}

// =====================================================
// ITEM CATEGORIES
// =====================================================

model ItemCategory {
  id String @id @default(uuid())

  accurateCategoryId Int? @unique

  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@index([name])
  @@map("item_categories")
}

// =====================================================
// UNITS
// =====================================================

model Unit {
  id String @id @default(uuid())

  accurateUnitId Int? @unique

  name String

  isActive Boolean @default(true)

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemUnits ItemUnit[]

  itemPrices ItemPrice[]

  defaultItems Item[]

  serviceMaterials   ServiceMaterial[]
  materialUsageItems MaterialUsageItem[]
  invoiceItems       InvoiceItem[]
  treatmentItems     TreatmentItem[]

  @@index([name])
  @@map("units")
}

// =====================================================
// ITEMS
// =====================================================

model Item {
  id String @id @default(uuid())

  categoryId           String?
  defaultUnitId        String?
  commissionCategoryId String?

  accurateItemId Int? @unique

  itemCode String @unique

  name String

  itemType ItemType

  isActive Boolean @default(true)

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category ItemCategory? @relation(fields: [categoryId], references: [id])

  defaultUnit Unit? @relation(fields: [defaultUnitId], references: [id])

  commissionCategory CommissionCategory? @relation(fields: [commissionCategoryId], references: [id])

  itemUnits ItemUnit[]

  itemPrices ItemPrice[]

  inventories         Inventory[]
  stockMovements      StockMovement[]
  stockTransferItems  StockTransferItem[]
  appointmentServices AppointmentService[]
  invoiceItems        InvoiceItem[]
  commissions         Commission[]
  treatmentItems      TreatmentItem[]
  materialUsageItems  MaterialUsageItem[]
  serviceMaterials    ServiceMaterial[]    @relation("ServiceMaterials")
  usedAsMaterial      ServiceMaterial[]    @relation("MaterialItems")

  @@index([itemType])
  @@index([categoryId])
  @@index([defaultUnitId])
  @@index([commissionCategoryId])
  @@index([name])
  @@map("items")
}

// =====================================================
// ITEM UNITS
// =====================================================

model ItemUnit {
  id String @id @default(uuid())

  itemId String
  unitId String

  conversionFactor Decimal @db.Decimal(18, 6)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Item @relation(fields: [itemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([itemId, unitId])
  @@index([itemId])
  @@index([unitId])
  @@map("item_units")
}

// =====================================================
// ITEM PRICES
// =====================================================

model ItemPrice {
  id String @id @default(uuid())

  itemId String
  unitId String

  branchId String?

  sellingPrice Decimal  @db.Decimal(18, 2)
  costPrice    Decimal? @db.Decimal(18, 2)

  effectiveDate DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Item @relation(fields: [itemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([itemId])
  @@index([unitId])
  @@index([branchId])
  @@map("item_prices")
}

// =====================================================
// INVENTORY
// =====================================================

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

// =====================================================
// WAREHOUSES
// =====================================================

model Warehouse {
  id String @id @default(uuid())

  branchId String? @unique

  accurateWarehouseId Int? @unique

  name String

  isActive Boolean @default(true)

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  inventories Inventory[]

  stockMovements StockMovement[]

  transferOuts StockTransfer[] @relation("TransferSource")

  transferIns StockTransfer[] @relation("TransferDestination")

  @@index([branchId])
  @@map("warehouses")
}

// =====================================================
// INVENTORIES
// =====================================================

model Inventory {
  id String @id @default(uuid())

  warehouseId String

  itemId String

  availableQty Decimal @db.Decimal(18, 6)

  reservedQty Decimal @db.Decimal(18, 6)

  minimumQty Decimal @db.Decimal(18, 6)

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  item Item @relation(fields: [itemId], references: [id])

  @@unique([warehouseId, itemId])
  @@index([warehouseId])
  @@index([itemId])
  @@map("inventories")
}

// =====================================================
// STOCK MOVEMENTS
// =====================================================

model StockMovement {
  id String @id @default(uuid())

  warehouseId String

  itemId String

  invoiceItemId String?

  type StockMovementType

  qty Decimal @db.Decimal(18, 6)

  balanceBefore Decimal @db.Decimal(18, 6)

  balanceAfter Decimal @db.Decimal(18, 6)

  referenceType String?

  referenceId String?

  notes String?

  createdAt DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  item Item @relation(fields: [itemId], references: [id])

  invoiceItem InvoiceItem? @relation(fields: [invoiceItemId], references: [id])

  @@unique([referenceType, referenceId, invoiceItemId])
  @@index([warehouseId])
  @@index([itemId])
  @@index([invoiceItemId])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

// =====================================================
// STOCK TRANSFERS
// =====================================================

model StockTransfer {
  id String @id @default(uuid())

  sourceWarehouseId String

  destinationWarehouseId String

  transferNo String @unique

  status StockTransferStatus

  notes String?

  transferDate DateTime

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceWarehouse Warehouse @relation("TransferSource", fields: [sourceWarehouseId], references: [id])

  destinationWarehouse Warehouse @relation("TransferDestination", fields: [destinationWarehouseId], references: [id])

  items StockTransferItem[]

  @@index([sourceWarehouseId])
  @@index([destinationWarehouseId])
  @@map("stock_transfers")
}

// =====================================================
// STOCK TRANSFER ITEMS
// =====================================================

model StockTransferItem {
  id String @id @default(uuid())

  transferId String

  itemId String

  qty Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  transfer StockTransfer @relation(fields: [transferId], references: [id])

  item Item @relation(fields: [itemId], references: [id])

  @@index([transferId])
  @@index([itemId])
  @@map("stock_transfer_items")
}

// =====================================================
// SERVICE BOM
// =====================================================

model ServiceMaterial {
  id String @id @default(uuid())

  serviceItemId  String
  materialItemId String

  unitId String

  qty Decimal @db.Decimal(18, 6)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceItem Item @relation("ServiceMaterials", fields: [serviceItemId], references: [id])

  materialItem Item @relation("MaterialItems", fields: [materialItemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([serviceItemId, materialItemId])
  @@index([serviceItemId])
  @@index([materialItemId])
  @@map("service_materials")
}

// =====================================================
// MATERIAL USAGES
// =====================================================

model MaterialUsage {
  id String @id @default(uuid())

  treatmentItemId String

  processedAt DateTime

  createdAt DateTime @default(now())

  treatmentItem TreatmentItem @relation(fields: [treatmentItemId], references: [id])

  usageItems MaterialUsageItem[]

  @@index([treatmentItemId])
  @@map("material_usages")
}

// =====================================================
// MATERIAL USAGE ITEMS
// =====================================================

model MaterialUsageItem {
  id String @id @default(uuid())

  materialUsageId String

  materialItemId String

  unitId String

  stockMovementId String?

  qty Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  materialUsage MaterialUsage @relation(fields: [materialUsageId], references: [id])

  materialItem Item @relation(fields: [materialItemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([materialUsageId])
  @@index([materialItemId])
  @@map("material_usage_items")
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CHECK_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  SALON
  HOME_SERVICE
}

enum AppointmentPhotoType {
  REFERENCE
  HAIR_CURRENT
}

enum DepositStatus {
  PENDING
  UNPAID
  PARTIAL
  PAID
  PARTIAL_USED
  USED
  REFUNDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

model Appointment {
  id String @id @default(uuid())

  customerId String
  branchId   String

  bookingNo String @unique

  bookingDate DateTime

  visitDate DateTime

  startTime DateTime
  endTime   DateTime

  status AppointmentStatus

  type             AppointmentType @default(SALON)
  homeServiceAddress String?

  notes String?

  estimatedTotal Decimal? @db.Decimal(18, 2)

  createdByEmployeeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer          Customer  @relation(fields: [customerId], references: [id])
  branch            Branch    @relation(fields: [branchId], references: [id])
  createdByEmployee Employee? @relation("AppointmentCreatedBy", fields: [createdByEmployeeId], references: [id])

  services AppointmentService[]

  staffs AppointmentStaff[]

  deposits Deposit[]

  invoices Invoice[]

  statusHistories AppointmentStatusHistory[]

  treatmentSessions TreatmentSession[]

  photos AppointmentPhoto[]

  @@index([customerId])
  @@index([branchId])
  @@index([visitDate])
  @@index([createdByEmployeeId])
  @@map("appointments")
}

model AppointmentPhoto {
  id            String               @id @default(uuid())
  appointmentId String
  url           String
  publicId      String
  type          AppointmentPhotoType @default(REFERENCE)
  notes         String?
  createdAt     DateTime             @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_photos")
}

model AppointmentService {
  id String @id @default(uuid())

  appointmentId String

  serviceItemId String

  durationMinutes Int

  qty Decimal @db.Decimal(18, 2)

  price Decimal @db.Decimal(18, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  serviceItem Item @relation(fields: [serviceItemId], references: [id])

  @@index([appointmentId])
  @@index([serviceItemId])
  @@map("appointment_services")
}

model AppointmentStaff {
  id String @id @default(uuid())

  appointmentId String

  employeeId String

  slotKey String?

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([appointmentId, employeeId])
  @@index([appointmentId])
  @@index([employeeId])
  @@map("appointment_staffs")
}

model Deposit {
  id String @id @default(uuid())

  customerId    String
  appointmentId String?

  branchId            String
  createdByEmployeeId String?

  amount Decimal @db.Decimal(18, 2)

  status DepositStatus

  paidAt DateTime?

  accurateDepositId     Int?    @unique
  accurateDepositNumber String?
  lastSyncAt            DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer          Customer    @relation(fields: [customerId], references: [id])
  appointment       Appointment? @relation(fields: [appointmentId], references: [id])
  branch            Branch    @relation(fields: [branchId], references: [id])
  createdByEmployee Employee? @relation("DepositCreatedBy", fields: [createdByEmployeeId], references: [id])

  invoiceDeposits InvoiceDeposit[]
  depositPayments DepositPayment[]

  @@index([customerId])
  @@index([appointmentId])
  @@index([branchId])
  @@index([createdByEmployeeId])
  @@map("deposits")
}

model DepositPayment {
  id String @id @default(uuid())

  depositId       String
  paymentMethodId String

  amount Decimal @db.Decimal(18, 2)

  paymentNo String @unique

  accurateReceiptId     Int?    @unique
  accurateReceiptNumber String?

  lastSyncAt DateTime?

  referenceNo String?
  notes       String?

  transferProofUrl      String?
  transferProofPublicId String?

  paidAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deposit       Deposit       @relation(fields: [depositId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([depositId])
  @@index([paymentMethodId])
  @@map("deposit_payments")
}

model AppointmentStatusHistory {
  id String @id @default(uuid())

  appointmentId String

  oldStatus AppointmentStatus?

  newStatus AppointmentStatus

  notes String?

  createdBy String?

  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@map("appointment_status_histories")
}

model CashAccount {
  id String @id @default(uuid())

  name String

  code String @unique

  accurateAccountId Int? @unique

  accurateAccountNo String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentMethods PaymentMethod[]

  @@map("cash_accounts")
}

model PaymentMethod {
  id String @id @default(uuid())

  cashAccountId String?

  code String @unique

  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cashAccount CashAccount? @relation(fields: [cashAccountId], references: [id])

  payments Payment[]

  depositPayments DepositPayment[]

  @@index([cashAccountId])
  @@map("payment_methods")
}

model Invoice {
  id String @id @default(uuid())

  customerId String

  branchId String

  appointmentId String?

  accurateInvoiceId Int? @unique

  accurateInvoiceNumber String?

  invoiceNo String @unique

  invoiceDate DateTime

  subtotal Decimal @db.Decimal(18, 2)

  totalDiscount Decimal @default(0) @db.Decimal(18, 2)

  totalDeposit Decimal @default(0) @db.Decimal(18, 2)

  totalTax Decimal @default(0) @db.Decimal(18, 2)

  grandTotal Decimal @db.Decimal(18, 2)

  paidAmount Decimal @default(0) @db.Decimal(18, 2)

  outstandingAmount Decimal @db.Decimal(18, 2)

  status InvoiceStatus

  notes String?

  taxable      Boolean   @default(false)

  inclusiveTax Boolean   @default(false)

  taxDate      DateTime?

  lastSyncAt DateTime?

  createdByEmployeeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer          Customer   @relation(fields: [customerId], references: [id])
  branch            Branch     @relation(fields: [branchId], references: [id])
  appointment       Appointment? @relation(fields: [appointmentId], references: [id])
  createdByEmployee Employee?  @relation("InvoiceCreatedBy", fields: [createdByEmployeeId], references: [id])

  items InvoiceItem[]

  payments Payment[]

  invoiceDeposits InvoiceDeposit[]

  statusHistories InvoiceStatusHistory[]

  treatmentSessions TreatmentSession[]

  commissions Commission[]

  consultationNote ClientConsultationNote?

  @@index([customerId])
  @@index([branchId])
  @@index([appointmentId])
  @@index([createdByEmployeeId])
  @@map("invoices")
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String

  itemId String

  unitId String

  accurateInvoiceDetailId Int?

  qty Decimal @db.Decimal(18, 2)

  price Decimal @db.Decimal(18, 2)

  discount        Decimal  @default(0) @db.Decimal(18, 2)

  discountType    String   @default("AMOUNT")

  discountPercent Decimal? @db.Decimal(5, 2)

  subtotal Decimal @db.Decimal(18, 2)

  taxable  Boolean   @default(false)

  taxName  String?

  taxRate  Decimal   @default(0) @db.Decimal(18, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  item Item @relation(fields: [itemId], references: [id])

  unit Unit @relation(fields: [unitId], references: [id])

  commissions    Commission[]
  stockMovements StockMovement[]

  @@index([invoiceId])
  @@index([itemId])
  @@index([unitId])
  @@map("invoice_items")
}

model Payment {
  id String @id @default(uuid())

  invoiceId String

  paymentMethodId String

  branchId            String
  createdByEmployeeId String?

  paymentNo String @unique

  amount Decimal @db.Decimal(18, 2)

  paymentDate DateTime

  referenceNo String?

  notes String?

  accurateReceiptId     Int?      @unique
  accurateReceiptNumber String?
  lastSyncAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice           Invoice   @relation(fields: [invoiceId], references: [id])
  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  branch            Branch    @relation(fields: [branchId], references: [id])
